authEndpoint: &authEndpoint https://{{ .hostname }}:{{.kcPort }}/auth
issuerEndpoint: &issuerEndpoint https://{{ .hostname }}:{{.kcPort }}/auth/realms/{{.authRealm}}
tokenEndpoint: &tokenEndpoint https://{{ .hostname }}:{{.kcPort }}/auth/realms/{{.authRealm}}/protocol/openid-connect/token
entityResolutionServiceUrl: &entityResolutionServiceUrl https://{{ .hostname }}:{{.platformPort }}/entityresolution/resolve
platformEndpoint: &platformEndpoint https://{{.hostname }}:{{.platformPort }}
taggingEndpoint: &taggingEndpoint localhost:{{.taggingPort }}
authRealm: &authRealm {{.authRealm}}
mode: all
logger:
  level: debug
  type: text
  output: stdout
db:
  host: {{ .pgHost }}
  port: {{ .pgPort }}
  database: {{ .pgDatabase }}
  user: postgres
  password: changeme
  schema: otdf
services:
  policyimportexport:
    privatesignkey: {{.otdfKeysDir}}/policyimportexport/cosign.key
    privatesignkeypassphrasepath: {{.otdfKeysDir}}/policyimportexport/cosign.pass
    truststore: {{.otdfKeysDir}}/policyimportexport
  kas:
    keyring:
      - kid: e1
        alg: ec:secp256r1
      - kid: r1
        alg: rsa:2048
  entityresolution:
    url: *authEndpoint
    clientid: 'tdf-entity-resolution'
    clientsecret: 'secret'
    realm: *authRealm
    legacykeycloak: true
    inferid:
      from:
        email: true
        username: true
  shared:
    clientId: otdf-shared
    clientSecret: secret
    authClientId: otdf-shared-auth
    serviceHostName: shared
    platformEndpoint: *platformEndpoint
    platformAuthEndpoint: *authEndpoint
    platformAuthRealm: *authRealm
    tokenEndpoint: *tokenEndpoint
  # ...other service configs as needed...
